# QUESTPAUSE Sentinel — Environment Configuration

# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Discord Client ID (for slash command registration)
DISCORD_CLIENT_ID=your_client_id_here

# Discord Guild ID for development (leave empty for global commands)
DISCORD_GUILD_ID=

# Report alert channel ID (optional — if set, player reports are forwarded here)
SENTINEL_REPORT_CHANNEL_ID=
