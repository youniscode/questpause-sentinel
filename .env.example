# QUESTPAUSE Sentinel — Environment Configuration

# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Discord Client ID (for slash command registration)
DISCORD_CLIENT_ID=your_client_id_here

# Discord Guild ID for development (leave empty for global commands)
DISCORD_GUILD_ID=

# Report alert channel ID (optional — if set, player reports are forwarded here)
SENTINEL_REPORT_CHANNEL_ID=

# Keyword guard alert channel ID (optional — if set, keyword triggers are sent here)
SENTINEL_ALERT_CHANNEL_ID=

# Channel allow/block for keyword guard (optional — comma-separated IDs)
# Leave empty to monitor all guild channels (minus blocked)
SENTINEL_MONITORED_CHANNEL_IDS=
SENTINEL_BLOCKED_CHANNEL_IDS=
SENTINEL_BLOCKED_CATEGORY_IDS=

# Game persona replies (optional — enable/disable and cooldown settings)
ENABLE_PERSONA_REPLIES=true
PERSONA_REPLY_COOLDOWN_MINUTES=15
PERSONA_PLAYER_COOLDOWN_MINUTES=30

# Per-game channel IDs for persona routing (optional — comma-separated)
# Messages in these channels will use the matching game's persona only
VALHEIM_CHANNEL_IDS=
PROJECT_ZOMBOID_CHANNEL_IDS=
ICARUS_CHANNEL_IDS=
WINDROSE_CHANNEL_IDS=
MINECRAFT_CHANNEL_IDS=
SEVEN_DAYS_TO_DIE_CHANNEL_IDS=
